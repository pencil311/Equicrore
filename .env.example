# ============================================================
# EQUICRORE — Environment Variables
# Copy this to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# --- Database (Phase 4) ---
# MongoDB Atlas connection string
# Use direct connection (avoids ISP SRV blocks — same fix as MoodSync)
MONGODB_URI=mongodb://username:password@cluster.mongodb.net/equicrore?directConnection=true

# --- Auth (Phase 4) ---
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# --- Market Data APIs (Phase 5) ---
# CoinGecko — free tier, no key needed for basic endpoints
# COINGECKO_API_KEY=optional-for-higher-rate-limits

# Alpha Vantage — free tier (500 req/day)
ALPHA_VANTAGE_KEY=your-key-here

# Yahoo Finance is used via the 'yahoo-finance2' npm package (no key needed)
